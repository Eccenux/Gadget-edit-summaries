	"version": "0.2.0",
	"configurations": [
		// note that "integratedTerminal" is required for `setupSummary`
		{
			"type": "node",
			"request": "launch",
			"name": "Run current JS",
			"console": "integratedTerminal",
			"skipFiles": [
				"<node_internals>/**"
			],
			"program": "${fileBasename}",
			"cwd": "${fileDirname}"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Deploy global",
			"console": "integratedTerminal",
			"skipFiles": [
				"<node_internals>/**"
			],
			"program": "${workspaceFolder}\\wikiploy.mjs"
		}
	]
}